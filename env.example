# LLM Configuration
# Option 1: OpenAI
OPENAI_API_KEY=your-openai-api-key-here
LLM_BACKEND=openai
LLM_MODEL=gpt-3.5-turbo

# Option 2: Ollama (free, local, no API key needed)
# Install Ollama: https://ollama.com
# Run: ollama pull llama3
# LLM_BACKEND=ollama
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434/v1

# Embedder Configuration
# "local" uses sentence-transformers (free, no API key)
# "openai" uses text-embedding-ada-002 (requires OPENAI_API_KEY)
EMBEDDER_BACKEND=local

# Vector Store
CHROMA_DIR=./chroma_db

# RAG Settings
TOP_K=5
SCORE_THRESHOLD=0.3
